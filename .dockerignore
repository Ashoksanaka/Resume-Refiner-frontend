!.env.example

# Git / IDE / docs
.git
.gitignore
.cursor
.vscode
.idea
*.md
!README.md

# Tests (not needed in production image)
tests
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
jest.config.*
jest.setup.*
playwright.config.*
scripts/check-backend-url.mjs

# Misc
Dockerfile*
docker-compose*.yml
.dockerignore
npm-debug.log*
