# Dependencies and build output
node_modules
.next
out
dist
coverage
playwright-report
test-results
*.tsbuildinfo
.swc/

# Accidental / local scan artifacts
env/
semgrep.json

# Env / secrets — bake via build args or runtime env, never COPY into image
.env
