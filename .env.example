# Clerk authentication (Clerk Dashboard → API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk route configuration (safe local/route defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# API configuration
# Client-side API base — keep as relative path for same-origin HTTPS proxy
# (browser never calls the AWS HTTP origin — avoids mixed content)
NEXT_PUBLIC_API_URL=/api/v1

# Server-only — never prefix with NEXT_PUBLIC_
# Local Next.js on the host (`npm run dev`):
#   BACKEND_URL=http://localhost:8000
# Docker Compose frontend container (service DNS — do NOT use localhost):
#   DOCKER_BACKEND_URL=http://backend:8000
# Vercel → HTTP AWS VM (Nginx on host :8080; interim until TLS):
#   BACKEND_URL=http://<AWS_ELASTIC_IP>:8080
#   ALLOW_INSECURE_BACKEND=true
# Prefer HTTPS when TLS is available:
#   BACKEND_URL=https://api.example.com
BACKEND_URL=
DOCKER_BACKEND_URL=
ALLOW_INSECURE_BACKEND=

# E2E testing — required when running Playwright
PLAYWRIGHT_BASE_URL=http://localhost:3000
